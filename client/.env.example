# Client environment variables
# Copy to .env.local for local development

# Socket.IO server URL (change to Render URL for production)
REACT_APP_SERVER_URL=http://localhost:5001

# Solana network: 'devnet' or 'mainnet-beta'
REACT_APP_SOLANA_NETWORK=devnet

# On-chain program IDs
REACT_APP_ESCROW_PROGRAM_ID=4kzrDpV9JxjE27AMg4PQXzGuge9MEYQEFznSPvkBtnH1
# v2 escrow — 2-10 player wagered group chat matches
REACT_APP_ESCROW_V2_PROGRAM_ID=BVKXLUnukU9cyTAWojsQPfLWHq4CyJY7CLG59bBVSG7N
REACT_APP_SHOT_TOKEN_MINT=4NnYBycLLo8acgbkLz2SyCXd3KU8jgHQLEmrVypi5VLd

# Solana RPC (optional — defaults to public cluster URL)
# For mainnet, use a dedicated RPC like Helius/QuickNode for reliability
# REACT_APP_SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Privy embedded wallet (Phase 2 of Syndicate-pattern migration).
# Public App ID — safe to commit. Get from dashboard.privy.io.
REACT_APP_PRIVY_APP_ID=cmorbf1nk00z10cidg6jitsgm

# CS-03: Prevent CRA from injecting inline scripts (CSP compliance)
INLINE_RUNTIME_CHUNK=false
