# DEEPER (DrillDeep) — environment variables
# Copy to .env for local dev; set the same keys in the Vercel project (Settings → Env).
# The game is fully playable with NONE of these (local-first). They light up the Arcade:
# the shared leaderboard + per-user cloud save via the SolShot backend, and Arcade login.

# SolShot backend (The Arcade server), e.g. https://solshot.onrender.com
VITE_SOLSHOT_API_BASE=

# Privy — the SAME app id used across The Arcade (web login outside Telegram)
VITE_PRIVY_APP_ID=
