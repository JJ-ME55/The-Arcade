# Privy — paste the existing SolShot app ID here. Same app, different origin.
# Get from https://dashboard.privy.io. Allowed origins must include your
# arcade.vercel.app preview URL AND localhost:5173 — JJ adds these in the dashboard.
VITE_PRIVY_APP_ID=

# SolShot server base URL — Render hostname that hosts the existing
# Express + Socket.IO + Telegraf process. Used for leaderboard reads,
# score submission, and the /api/arcade/session-handoff endpoint when
# redirecting to solshot.gg.
VITE_SOLSHOT_API_BASE=https://your-render-hostname.onrender.com

# Solana — match SolShot's existing config. Devnet for now, swap to
# mainnet-beta when the platform goes live.
VITE_SOLANA_NETWORK=devnet
VITE_SOLANA_RPC=https://api.devnet.solana.com

# solshot.gg URL the SolShot tile redirects to. Token gets appended as
# ?arcade_token=<jwt> via the session-handoff flow.
VITE_SOLSHOT_WEB_URL=https://solshot.gg
