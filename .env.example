# DEEPER — environment variables
# Copy to .env for local dev; set the same keys in the Vercel project (Settings → Env).
# The game is fully playable with NONE of these (local-first). They enable the cloud:
# per-user save sync across web+mobile, the Arcade login, and the shared leaderboard.

# Supabase project (Project Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Privy — the SAME app id used across The Arcade (so logins/identity carry over)
VITE_PRIVY_APP_ID=
