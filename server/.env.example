# Server
PORT=5001
NODE_ENV=development

# CORS — comma-separated allowed origins (defaults to http://localhost:3000)
# CORS_ORIGINS=https://solshot.gg,https://www.solshot.gg

# MongoDB (optional — runs without DB for dev/devnet)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/solshot?retryWrites=true&w=majority

# Solana
# Development: https://api.devnet.solana.com
# Production:  Use dedicated RPC (Helius, QuickNode, etc.)
SOLANA_RPC=https://api.devnet.solana.com

# Server keypair — use ONE of these two options:
# Option A: File path (local dev)
SOLANA_KEYPAIR_PATH=~/.config/solana/solshot-dev.json
# Option B: Raw JSON array (cloud deploy — paste contents of keypair file)
# SOLANA_KEYPAIR_JSON=[1,2,3,...,64]

# On-chain programs (devnet)
MATCH_ESCROW_PROGRAM_ID=4kzrDpV9JxjE27AMg4PQXzGuge9MEYQEFznSPvkBtnH1
SHOT_TOKEN_MINT=4NnYBycLLo8acgbkLz2SyCXd3KU8jgHQLEmrVypi5VLd

# Wallets for settlement split (90% winner, 7% treasury, 3% ops)
TREASURY_WALLET=4Ekd8xxsym6HiGaKbDVP7hgf3AoBsLmBSenyfx3N2hGk
OPS_WALLET=G2TgxypFAQHvcfwRA1dkJMx2St4gYpDpz37uiG1Q9grx

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string

# Jupiter Price API (free Lite tier from portal.jup.ag)
JUP_API_KEY=your-jupiter-api-key-here

# Telegram Mini App (optional — get token from @BotFather)
# Without this, Telegram initData validation is skipped (game still works, just no TG identity)
# and the bot command handler is disabled.
TELEGRAM_BOT_TOKEN=

# Telegram bot webhook URL — your server's public base URL.
# In production (Render): https://solshot-server.onrender.com (no trailing slash, no path)
# Bot will register webhook at <URL>/api/telegram-webhook automatically.
# Leave blank in dev — bot falls back to long polling.
TELEGRAM_WEBHOOK_URL=

# Optional: random secret string. If set, Telegram includes it as a header
# on every webhook call and we validate it. Recommended in production.
TELEGRAM_WEBHOOK_SECRET=

# Optional: override the URL the bot's inline keyboard buttons link to.
# Defaults to https://solshot.gg/ — the SolShot PWA at our domain. URL
# buttons open in the in-app browser (TG iOS) / default browser (TG
# Desktop / Web) — a top-level browsing context, NOT a Mini App iframe.
# This is the Syndicate / Banana Gun / Trojan architecture.
# Variable name kept as MINI_APP_URL for backwards compat; semantic is
# now "the URL the bot links to."
MINI_APP_URL=
